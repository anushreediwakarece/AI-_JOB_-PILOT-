# Copy this file to `.env.local` and fill in your own values.
# `.env.local` is gitignored — never commit real secrets.

# --- InsForge backend (required) ---
NEXT_PUBLIC_INSFORGE_URL=https://your-app.region.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=your-insforge-anon-key

# --- AI: Google Gemini (required) ---
GEMINI_API_KEY=your-gemini-api-key

# --- Live jobs: RapidAPI JSearch (required) ---
RAPIDAPI_KEY=your-rapidapi-key

# --- Analytics: PostHog (optional) ---
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-ingest-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Browserbase (optional / reserved — NOT currently used) ---
# BROWSERBASE_API_KEY=
# BROWSERBASE_PROJECT_ID=
